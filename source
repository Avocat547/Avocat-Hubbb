local function bypassAC()
    local bp={}
    pcall(function() for _,v in ipairs(game:GetDescendants()) do pcall(function() local n=v.Name:lower()
        if n:find("adonis") or n:find("adonis_loader") or n:find("mainmodule") then if v:IsA("LocalScript") then v.Disabled=true table.insert(bp,"Adonis: "..v.Name) end if v:IsA("ModuleScript") then pcall(function() v:Destroy() end) table.insert(bp,"Adonis Module: "..v.Name) end end
        if n:find("hdadmin") or n:find("hd_admin") or n:find("hd admin") then if v:IsA("LocalScript") then v.Disabled=true table.insert(bp,"HD Admin: "..v.Name) end if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) and getconnections then for _,conn in ipairs(getconnections(v.OnClientEvent or v.OnClientInvoke)) do pcall(function() conn:Disable() end) end table.insert(bp,"HD Remote: "..v.Name) end end
        if n:find("kohls") or n:find("kohl") then if v:IsA("LocalScript") then v.Disabled=true table.insert(bp,"Kohls: "..v.Name) end end
        if n:find("bsod") or n:find("bluescreen") or n:find("crash_handler") then if v:IsA("LocalScript") then v.Disabled=true table.insert(bp,"Crash: "..v.Name) end if v:IsA("ScreenGui") then v:Destroy() table.insert(bp,"Crash GUI: "..v.Name) end end
        if (v:IsA("LocalScript") or v:IsA("ModuleScript")) and (n:find("anticheat") or n:find("anti_cheat") or n:find("cheatdetect") or n:find("exploitdetect") or n:find("securitycheck") or n:find("ac_") or n:find("detection") or n:find("checker")) then v.Disabled=true table.insert(bp,"AC Script: "..v.Name) end
        if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) and (n:find("kick") or n:find("ban") or n:find("punish") or n:find("speed") or n:find("teleport") or n:find("noclip") or n:find("fly")) and getconnections then for _,conn in ipairs(getconnections(v.OnClientEvent or v.OnClientInvoke)) do pcall(function() conn:Disable() end) end table.insert(bp,"Remote: "..v.Name) end
    end) end end)
    pcall(function() local af=RS:FindFirstChild("MainModule") or RS:FindFirstChild("Adonis_Loader") if af then pcall(function() af:Destroy() end) table.insert(bp,"Adonis Loader supprime") end end)
    pcall(function() for _,v in ipairs(RS:GetDescendants()) do pcall(function() if v.Name:lower():find("adonis") then if v:IsA("LocalScript") then v.Disabled=true end if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) and getconnections then for _,conn in ipairs(getconnections(v.OnClientEvent or v.OnClientInvoke)) do pcall(function() conn:Disable() end) end table.insert(bp,"Adonis RS Remote: "..v.Name) end end end) end end)
    pcall(function() if hookfunction and getrawmetatable then local mt=getrawmetatable(game) if mt then local old=mt.__namecall setreadonly(mt,false) mt.__namecall=newcclosure(function(self,...) if getnamecallmethod()=="Kick" then return end return old(self,...) end) setreadonly(mt,true) table.insert(bp,"Kick hook") end end end)
    pcall(function() if hookfunction then local oldErr=error hookfunction(error,function(...) return end) table.insert(bp,"Error hook") end end)
    pcall(function() if getconnections then for _,c in ipairs(getconnections(lp.Idled)) do c:Disable() end table.insert(bp,"Anti idle") end end)
    if #bp>0 then warn("[Avocat Hub] Bypass actif - "..#bp.." elements:") for _,b in ipairs(bp) do warn("  > "..b) end game:GetService("StarterGui"):SetCore("SendNotification",{Title="AC Bypass",Text=#bp.." elements bypass",Duration=3})
    else warn("[Avocat Hub] Aucun anti-cheat detecte") game:GetService("StarterGui"):SetCore("SendNotification",{Title="AC Bypass",Text="Aucun AC detecte",Duration=3}) end
end
tAdonis.on(function(s) if s then bypassAC() end end)

