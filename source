local KEY = "AvocatV2-2025"  -- change ta key ici

local Players     = game:GetService("Players")
local CoreGui     = game:GetService("CoreGui")
local TweenService= game:GetService("TweenService")
local UIS         = game:GetService("UserInputService")
local HS          = game:GetService("HttpService")
local LP          = Players.LocalPlayer

-- cleanup si re-exec
pcall(function()
    if CoreGui:FindFirstChild("AvocatKey") then
        CoreGui:FindFirstChild("AvocatKey"):Destroy()
    end
    if CoreGui:FindFirstChild("AvocatHubV2") then
        CoreGui:FindFirstChild("AvocatHubV2"):Destroy()
    end
end)

-- couleurs
local CLR = {
    Bg   = Color3.fromRGB(12, 12, 18),
    Bg2  = Color3.fromRGB(20, 20, 28),
    Ac   = Color3.fromRGB(140, 80, 255),
    AcH  = Color3.fromRGB(170, 110, 255),
    W    = Color3.fromRGB(255, 255, 255),
    Dim  = Color3.fromRGB(110, 110, 130),
    R    = Color3.fromRGB(200, 60, 60),
    G    = Color3.fromRGB(80, 200, 100),
}

local gui = Instance.new("ScreenGui")
gui.Name = "AvocatKey"
gui.Parent = CoreGui
gui.ResetOnSpawn = false

-- box principal
local box = Instance.new("Frame")
box.Parent = gui
box.BackgroundColor3 = CLR.Bg
box.BorderSizePixel = 0
box.AnchorPoint = Vector2.new(0.5, 0.5)
box.Position = UDim2.new(0.5, 0, 0.5, 0)
box.Size = UDim2.new(0, 0, 0, 0)
box.Active = true
Instance.new("UICorner", box).CornerRadius = UDim.new(0, 12)

local stroke = Instance.new("UIStroke", box)
stroke.Color = CLR.Ac
stroke.Thickness = 1.5

-- accent bar gauche
local bar = Instance.new("Frame", box)
bar.BackgroundColor3 = CLR.Ac
bar.BorderSizePixel = 0
bar.Size = UDim2.new(0, 3, 0.6, 0)
bar.Position = UDim2.new(0, 0, 0.2, 0)
Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 2)

-- titre
local title = Instance.new("TextLabel", box)
title.BackgroundTransparency = 1
title.Position = UDim2.new(0, 20, 0, 18)
title.Size = UDim2.new(1, -40, 0, 28)
title.Font = Enum.Font.GothamBold
title.Text = "AVOCAT HUB V2"
title.TextColor3 = CLR.W
title.TextSize = 18
title.TextXAlignment = Enum.TextXAlignment.Left
title.TextTransparency = 1

-- sous-titre
local sub = Instance.new("TextLabel", box)
sub.BackgroundTransparency = 1
sub.Position = UDim2.new(0, 20, 0, 46)
sub.Size = UDim2.new(1, -40, 0, 16)
sub.Font = Enum.Font.Gotham
sub.Text = "Entrez la clé pour continuer"
sub.TextColor3 = CLR.Dim
sub.TextSize = 11
sub.TextXAlignment = Enum.TextXAlignment.Left
sub.TextTransparency = 1

-- input
local input = Instance.new("TextBox", box)
input.BackgroundColor3 = CLR.Bg2
input.BorderSizePixel = 0
input.Position = UDim2.new(0.08, 0, 0, 78)
input.Size = UDim2.new(0.84, 0, 0, 34)
input.Font = Enum.Font.Gotham
input.PlaceholderText = "Clé..."
input.PlaceholderColor3 = CLR.Dim
input.Text = ""
input.TextColor3 = CLR.W
input.TextSize = 13
input.ClearTextOnFocus = false
input.TextTransparency = 1
Instance.new("UICorner", input).CornerRadius = UDim.new(0, 8)
Instance.new("UIStroke", input).Color = Color3.fromRGB(35, 35, 50)

-- status
local status = Instance.new("TextLabel", box)
status.BackgroundTransparency = 1
status.Position = UDim2.new(0, 0, 0, 118)
status.Size = UDim2.new(1, 0, 0, 14)
status.Font = Enum.Font.Gotham
status.Text = ""
status.TextColor3 = CLR.R
status.TextSize = 10
status.TextTransparency = 1

-- barre de chargement
local loadBar = Instance.new("Frame", box)
loadBar.BackgroundColor3 = CLR.Bg2
loadBar.BorderSizePixel = 0
loadBar.Position = UDim2.new(0.08, 0, 0, 138)
loadBar.Size = UDim2.new(0.84, 0, 0, 4)
loadBar.Visible = false
Instance.new("UICorner", loadBar).CornerRadius = UDim.new(0, 2)

local loadFill = Instance.new("Frame", loadBar)
loadFill.BackgroundColor3 = CLR.Ac
loadFill.BorderSizePixel = 0
loadFill.Size = UDim2.new(0, 0, 1, 0)
Instance.new("UICorner", loadFill).CornerRadius = UDim.new(0, 2)

-- bouton
local btn = Instance.new("TextButton", box)
btn.BackgroundColor3 = CLR.Ac
btn.BorderSizePixel = 0
btn.Position = UDim2.new(0.08, 0, 0, 148)
btn.Size = UDim2.new(0.84, 0, 0, 34)
btn.Font = Enum.Font.GothamBold
btn.Text = "Valider"
btn.TextColor3 = CLR.W
btn.TextSize = 13
btn.AutoButtonColor = false
btn.TextTransparency = 1
Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

-- hover
btn.MouseEnter:Connect(function()
    TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = CLR.AcH}):Play()
end)
btn.MouseLeave:Connect(function()
    TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = CLR.Ac}):Play()
end)

-- drag
local drag, dragStart, dragPos = false, nil, nil
box.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        drag = true
        dragStart = i.Position
        dragPos = box.Position
        i.Changed:Connect(function()
            if i.UserInputState == Enum.UserInputState.End then drag = false end
        end)
    end
end)
UIS.InputChanged:Connect(function(i)
    if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
        local d = i.Position - dragStart
        box.Position = UDim2.new(dragPos.X.Scale, dragPos.X.Offset + d.X,
                                  dragPos.Y.Scale, dragPos.Y.Offset + d.Y)
    end
end)

-- animation d'entrée
TweenService:Create(box, TweenInfo.new(0.5, Enum.EasingStyle.Back),
    {Size = UDim2.new(0, 340, 0, 200)}):Play()
task.wait(0.3)
for _, v in ipairs({title, sub, input, status, btn}) do
    TweenService:Create(v, TweenInfo.new(0.25), {TextTransparency = 0}):Play()
    task.wait(0.08)
end

-- logique
local keyDone = false
local attempts = 0

btn.MouseButton1Click:Connect(function()
    local entered = input.Text:gsub("%s+", "")

    if entered == "" then
        status.Text = "Entrez une clé"
        status.TextColor3 = CLR.R
        return
    end

    attempts = attempts + 1

    if attempts > 5 then
        status.Text = "Trop de tentatives"
        task.wait(1)
        TweenService:Create(box, TweenInfo.new(0.3),
            {Size = UDim2.new(0, 0, 0, 0)}):Play()
        task.wait(0.4)
        gui:Destroy()
        return
    end

    if entered == KEY then
        status.Text = "Clé valide !"
        status.TextColor3 = CLR.G
        btn.Visible = false
        loadBar.Visible = true

        local steps = {"Vérification...", "Chargement...",
                       "Initialisation...", "Avocat Hub V2"}
        for i, t in ipairs(steps) do
            sub.Text = t
            TweenService:Create(loadFill, TweenInfo.new(0.4),
                {Size = UDim2.new(i / #steps, 0, 1, 0)}):Play()
            task.wait(0.5)
        end

        task.wait(0.3)
        TweenService:Create(box, TweenInfo.new(0.3, Enum.EasingStyle.Back,
            Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)}):Play()
        task.wait(0.4)
        gui:Destroy()
        keyDone = true
    else
        status.Text = "Clé invalide (" .. attempts .. "/5)"
        status.TextColor3 = CLR.R
        input.Text = ""
        -- shake
        local p = box.Position
        for _, offset in ipairs({8, -8, 4, -4, 0}) do
            TweenService:Create(box, TweenInfo.new(0.04),
                {Position = UDim2.new(p.X.Scale, p.X.Offset + offset,
                                       p.Y.Scale, p.Y.Offset)}):Play()
            task.wait(0.04)
        end
    end
end)

repeat task.wait(0.1) until keyDone

